BOT_TOKEN=
CLIENT_ID=
PORT=10000
FORM_BASE_URL=https://roleplayfrom.vercel.app

# Optional override. The bot defaults to namez-base when this is empty.
FIREBASE_DATABASE_URL=https://namez-base-default-rtdb.firebaseio.com

# Required when using the Firebase bridge. Paste a base64 encoded Firebase service account JSON.
# This must NOT be a https://...firebaseio.com URL.
FIREBASE_SERVICE_ACCOUNT_BASE64=

# Alternative: paste the raw Firebase service account JSON if your host supports multiline env vars.
FIREBASE_SERVICE_ACCOUNT=
